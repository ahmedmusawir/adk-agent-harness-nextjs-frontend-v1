# =============================================================================
# Environment Variables — Template
# =============================================================================
# To set up a new local environment:
#   1. Copy this file to .env.local       (cp .env.example .env.local)
#   2. Fill in the values below
#   3. .env.local is gitignored and never committed
#
# Get Supabase credentials from:
#   https://supabase.com/dashboard/project/_/settings/api
# =============================================================================


# Supabase project URL (browser-exposed)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable key (browser-exposed; respects RLS).
# Used by createClient() and middleware.
# This is what Supabase used to call the "anon key".
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key (server-side ONLY; bypasses ALL RLS).
# Used by createAdminClient() for portal admin operations.
# This is what Supabase used to call the "service_role key".
# Never expose to the browser. Never commit. Never log.
SUPABASE_SECRET_KEY=sb_secret_...

# Public site URL — used for auth redirects, email confirmation links, etc.
# Dev:        http://localhost:3000
# Staging:    https://your-staging.vercel.app
# Production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# ADK Agent Wrapper (BIM-001)
# -----------------------------------------------------------------------------

# Chat service mode: 'mock' | 'live'. Anything else (or unset) falls back to
# mock — the app must never accidentally ship live-wired.
NEXT_PUBLIC_CHAT_MODE=mock

# Python ADK wrapper base URL (server-side ONLY — no NEXT_PUBLIC prefix; never
# reaches the client bundle). Real value goes in .env.local only — never commit.
ADK_WRAPPER_URL=https://your-wrapper-service.your-region.run.app
